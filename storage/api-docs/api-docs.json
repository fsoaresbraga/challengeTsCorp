{
    "openapi": "3.0.0",
    "info": {
        "title": "Proposal Management API",
        "description": "REST API for client and proposal management (TsCorp challenge).",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "API base path"
        }
    ],
    "paths": {
        "/api/v1/clients": {
            "post": {
                "tags": [
                    "Clients"
                ],
                "description": "Register a new client (RF-01).",
                "operationId": "createClient",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "document"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Acme Corp"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "contact@acme.example"
                                    },
                                    "document": {
                                        "description": "CPF (11 digits) or alphanumeric CNPJ (RFB IN 2.229/2024)",
                                        "type": "string",
                                        "example": "12ABC34501DE35"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Client created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ClientResource"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/clients/{id}": {
            "get": {
                "tags": [
                    "Clients"
                ],
                "description": "Retrieve a client by ID (RF-02).",
                "operationId": "getClient",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Client found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ClientResource"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Client not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotFoundError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/proposals": {
            "post": {
                "tags": [
                    "Proposals"
                ],
                "description": "Create a new proposal in DRAFT status (RF-03). Requires Idempotency-Key header.",
                "operationId": "createProposal",
                "parameters": [
                    {
                        "name": "Idempotency-Key",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "create-proposal-abc-123"
                        }
                    },
                    {
                        "name": "X-Actor",
                        "in": "header",
                        "description": "Actor identifier: `system` or `user:{id}` (defaults to system)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "user:42"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "client_id",
                                    "product",
                                    "monthly_value",
                                    "origin"
                                ],
                                "properties": {
                                    "client_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "product": {
                                        "type": "string",
                                        "example": "Cloud Hosting Plan"
                                    },
                                    "monthly_value": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 299.9,
                                        "minimum": 0.01
                                    },
                                    "origin": {
                                        "type": "string",
                                        "example": "API",
                                        "enum": [
                                            "APP",
                                            "SITE",
                                            "API"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Proposal created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ProposalResource"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation or business rule error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "$ref": "#/components/schemas/ValidationError"
                                        },
                                        {
                                            "$ref": "#/components/schemas/BusinessError"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "BusinessError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Idempotency key reused with a different request payload."
                    }
                },
                "type": "object"
            },
            "ClientResource": {
                "required": [
                    "id",
                    "name",
                    "email",
                    "document",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Acme Corp"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "contact@acme.example"
                    },
                    "document": {
                        "type": "string",
                        "example": "12ABC34501DE35"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "NotFoundError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Client not found."
                    }
                },
                "type": "object"
            },
            "ProposalResource": {
                "required": [
                    "id",
                    "client_id",
                    "product",
                    "monthly_value",
                    "status",
                    "origin",
                    "version",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "client_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "product": {
                        "type": "string",
                        "example": "Cloud Hosting Plan"
                    },
                    "monthly_value": {
                        "type": "string",
                        "example": "299.90"
                    },
                    "status": {
                        "type": "string",
                        "example": "DRAFT",
                        "enum": [
                            "DRAFT",
                            "SUBMITTED",
                            "APPROVED",
                            "REJECTED",
                            "CANCELED"
                        ]
                    },
                    "origin": {
                        "type": "string",
                        "example": "API",
                        "enum": [
                            "APP",
                            "SITE",
                            "API"
                        ]
                    },
                    "version": {
                        "type": "integer",
                        "example": 1
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "ValidationError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Validation failed"
                    },
                    "errors": {
                        "type": "object"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Clients",
            "description": "Client management"
        },
        {
            "name": "Proposals",
            "description": "Proposal management"
        }
    ]
}